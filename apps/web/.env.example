# Public base URL of the HElbaron REST API (version-prefixed).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Default UI locale for the scaffold (en | ar). RTL is derived from this.
NEXT_PUBLIC_DEFAULT_LOCALE=en

# Public origin of this web app (used for sitemap/robots URLs).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
