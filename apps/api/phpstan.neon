includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    level: 5
    parallel:
        maximumNumberOfProcesses: 4
    paths:
        - app
        - config
        - database
        - routes
    # Establish the RC baseline; raise the level as findings are triaged.
    ignoreErrors: []
    excludePaths:
        - app/Domains/*/openapi/*
