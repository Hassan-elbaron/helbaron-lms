includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon
    - phpstan-architecture.neon

parameters:
    level: 6
    parallel:
        maximumNumberOfProcesses: 4
    paths:
        - app
        - config
        - database
        - routes
    # Level raised 5 -> 6 in Sprint 0 / A1-S02. Existing findings (the level-6 delta plus the
    # custom architecture rules) are captured in phpstan-baseline.neon; strictness only increases.
    ignoreErrors: []
    excludePaths:
        - app/Domains/*/openapi/*
        - app/Contexts/*/openapi/*
        - app/Platform/*/openapi/*
