# ---- Application ----
APP_NAME=HElbaron
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
# Supported locales (bilingual AR/EN). RTL handled on the frontend.
APP_SUPPORTED_LOCALES=en,ar

# ---- Logging ----
LOG_CHANNEL=stack
LOG_LEVEL=debug

# ---- Database (PostgreSQL) ----
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=55432
DB_DATABASE=helbaron
DB_USERNAME=helbaron
DB_PASSWORD=secret

# ---- Cache / Queue / Session (Redis + Horizon) ----
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6380
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ---- Filesystem (S3 + CloudFront) ----
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=me-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
CLOUDFRONT_URL=

# ---- Video (Mux) ----
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_SIGNING_KEY_ID=
MUX_SIGNING_KEY_PRIVATE=

# ---- Sanctum (SPA) ----
SANCTUM_STATEFUL_DOMAINS=localhost:3000
FRONTEND_URL=http://localhost:3000

# ---- Horizon ----
HORIZON_PREFIX=helbaron_horizon

# ---- Mail (local: log only; never sends real email) ----
MAIL_MAILER=log
MAIL_FROM_ADDRESS=no-reply@helbaron.local
MAIL_FROM_NAME=HElbaron

# ---------------------------------------------------------------------------
# Step 14 — External Integrations (all optional; empty => fake providers)
# Local/test MUST stay on fake providers. Production sets these + the *_PROVIDER
# selectors below. Never commit real secrets.
# ---------------------------------------------------------------------------

# Payments — Stripe (COMMERCE_PAYMENT_PROVIDER=stripe to enable)
COMMERCE_PAYMENT_PROVIDER=fake
STRIPE_BASE_URL=https://api.stripe.com
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE=300

# Video — Mux signed playback (LEARNING_PLAYBACK_PROVIDER=mux)
LEARNING_PLAYBACK_PROVIDER=fake
MUX_SIGNING_KEY_ID=
MUX_SIGNING_KEY=
MUX_STREAM_BASE_URL=https://stream.mux.com
MUX_TOKEN_AUDIENCE=v

# Private media via CloudFront (LEARNING_PLAYBACK_PROVIDER=cloudfront)
CLOUDFRONT_URL=
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY=

# S3 (also used for certificate/export storage disks)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Storage disk selection for signed downloads (local | s3)
CERTIFICATION_PDF_DISK=local
ANALYTICS_EXPORT_DISK=local

# Email — Mailgun (NOTIFICATIONS_MAIL_PROVIDER=mailgun)
NOTIFICATIONS_MAIL_PROVIDER=fake
MAILGUN_BASE_URL=https://api.mailgun.net
MAILGUN_DOMAIN=
MAILGUN_SECRET=
MAILGUN_FROM=

# SMS — Twilio (NOTIFICATIONS_SMS_PROVIDER=twilio)
NOTIFICATIONS_SMS_PROVIDER=fake
TWILIO_BASE_URL=https://api.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Push — Firebase FCM (NOTIFICATIONS_PUSH_PROVIDER=firebase)
NOTIFICATIONS_PUSH_PROVIDER=fake
FIREBASE_BASE_URL=https://fcm.googleapis.com
FIREBASE_SERVER_KEY=

# ---------------------------------------------------------------------------
# Step 15 — Production hardening (safe local defaults; tighten in production)
# ---------------------------------------------------------------------------
APP_VERSION=1.0.0-rc.1

# Security headers / CSP / HSTS
SECURITY_FRAME_OPTIONS=DENY
SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
SECURITY_PERMISSIONS_POLICY=geolocation=(), microphone=(), camera=(), payment=()
SECURITY_CSP=default-src 'none'; frame-ancestors 'none'; base-uri 'none'; form-action 'none'
SECURITY_HSTS_ENABLED=true
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_HSTS_PRELOAD=true

# Trusted proxies / hosts (behind ALB/CloudFront). APP_TRUSTED_HOSTS empty = no host restriction.
TRUSTED_PROXIES=*
APP_TRUSTED_HOSTS=

# Sessions / cookies (production: HTTPS => secure cookie true)
SESSION_DRIVER=redis
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SESSION_HTTP_ONLY=true
SESSION_ENCRYPT=true

# CORS (comma-separated allow-list; never *)
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_SUPPORTS_CREDENTIALS=true

# Logging (production: json to stdout)
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# Queue / Horizon
QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database-uuids
HORIZON_DEFAULT_MAX_PROCESSES=4
HORIZON_NOTIFICATIONS_MAX_PROCESSES=6
HORIZON_EXPORTS_MAX_PROCESSES=2

# Require confirmed MFA for /admin access (recommended in production)
ADMIN_REQUIRE_MFA=false
