{
    "name": "helbaron/api",
    "type": "project",
    "description": "HElbaron API — Laravel 12 modular monolith (scaffold).",
    "keywords": ["laravel", "lms", "helbaron"],
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "bezhansalleh/filament-shield": "^4.0",
        "chillerlan/php-qrcode": "^5.0",
        "ezyang/htmlpurifier": "^4.19",
        "filament/filament": "^4.0",
        "laravel/framework": "^12.0",
        "laravel/horizon": "^5.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.9",
        "league/flysystem-aws-s3-v3": "^3.0",
        "predis/predis": "^2.2",
        "sentry/sentry-laravel": "^4.26",
        "spatie/laravel-permission": "^6.0"
    },
    "require-dev": {
        "deptrac/deptrac": "^4.2",
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.13",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@php artisan package:discover --ansi"
        ],
        "test": "@php artisan test",
        "pint": "pint",
        "lint": "pint --test",
        "stan": "phpstan analyse --memory-limit=1G",
        "arch": "deptrac analyse --no-progress",
        "rector": "rector process --dry-run",
        "qa": [
            "@lint",
            "@stan",
            "@arch",
            "@test"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
